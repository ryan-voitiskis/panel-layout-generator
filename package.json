{
  "name": "panel-layout-generator",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && node scripts/clean-dist.mjs && vite build && node scripts/prepare-sites-build.mjs",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run test:coverage && npm run build"
  },
  "dependencies": {
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-accessible-color-picker": "^6.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "^7.0.2",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vue-tsc": "^3.3.7"
  },
  "prettier": {
    "semi": false,
    "vueIndentScriptAndStyle": true
  }
}
